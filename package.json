  "description": "Cricket Live Score Broadcasting with OBS Integration",
  "main": "src/main.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run react\"",
    "server": "node src/backend/server.js",
